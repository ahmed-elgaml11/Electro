{
  "info": {
    "name": "Task Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/auth/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "auth", "register"]}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/auth/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "auth", "login"]}
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Project\",\n  \"description\": \"Project description here\",\n  \"status\": \"pending\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/projects", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects"]}
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects"]}
          }
        },
        {
          "name": "Get Single Project",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":id"], "variable": [{"key": "id", "value": "PROJECT_ID_HERE"}]}
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"status\": \"in-progress\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/projects/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":id"], "variable": [{"key": "id", "value": "PROJECT_ID_HERE"}]}
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":id"], "variable": [{"key": "id", "value": "PROJECT_ID_HERE"}]}
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Task\",\n  \"description\": \"Task description\",\n  \"dueDate\": \"2026-12-31T00:00:00Z\",\n  \"priority\": \"high\",\n  \"status\": \"pending\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/projects/:projectId/tasks", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":projectId", "tasks"], "variable": [{"key": "projectId", "value": "PROJECT_ID_HERE"}]}
          }
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects/:projectId/tasks?status=pending&priority=high", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":projectId", "tasks"], "query": [{"key": "status", "value": "pending"}, {"key": "priority", "value": "high"}], "variable": [{"key": "projectId", "value": "PROJECT_ID_HERE"}]}
          }
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects/:projectId/tasks/:taskId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":projectId", "tasks", ":taskId"], "variable": [{"key": "projectId", "value": "PROJECT_ID_HERE"}, {"key": "taskId", "value": "TASK_ID_HERE"}]}
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\",\n  \"priority\": \"low\"\n}"
            },
            "url": {"raw": "http://localhost:3000/api/v1/projects/:projectId/tasks/:taskId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":projectId", "tasks", ":taskId"], "variable": [{"key": "projectId", "value": "PROJECT_ID_HERE"}, {"key": "taskId", "value": "TASK_ID_HERE"}]}
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}],
            "url": {"raw": "http://localhost:3000/api/v1/projects/:projectId/tasks/:taskId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "projects", ":projectId", "tasks", ":taskId"], "variable": [{"key": "projectId", "value": "PROJECT_ID_HERE"}, {"key": "taskId", "value": "TASK_ID_HERE"}]}
          }
        }
      ]
    }
  ]
}
